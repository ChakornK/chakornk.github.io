---
import Layout from "@/layouts/Layout.astro";

import type { GetStaticPaths } from "astro";
import ProjectLinks from "@/components/ProjectLinks.astro";
import ChipList from "@/components/ChipList.astro";

const projects = import.meta.glob("/content/{projects,projects-hackathon}/*.md", { eager: true });
const project = Object.entries(projects).find(([k, p]) => k.split("/").slice(-1)[0].split("-").slice(1).join("-").split(".")[0] === Astro.params.id)![1];
const { Content, frontmatter } = project as Record<string, any>;
const projectId = Astro.params.id;

export const getStaticPaths = (() => {
  const matches = import.meta.glob("/content/{projects,projects-hackathon}/*.md", { eager: true });
  const projects = Object.keys(matches).map((p) => p.split("/").slice(-1)[0].split("-").slice(1).join("-").split(".")[0]);
  return projects.map((p) => ({ params: { id: p } }));
}) satisfies GetStaticPaths;
---

<Layout
  title={frontmatter.name}
  description={frontmatter.description}
  class="prose prose-slate prose-strong:font-bold prose-h1:font-medium prose-li:marker:text-inherit prose-img:max-h-96 prose-h1:font-sans prose-img:max-w-full prose-img:object-contain *:w-full flex max-w-2xl flex-col items-center"
>
  <div class="bg-background pointer-events-none fixed inset-0 -z-10 opacity-0" data-project-bg={projectId}></div>
  <div id="project-header" class="sticky top-14 z-20 flex flex-col-reverse pb-2 transition-all duration-200 sm:flex-row">
    <div class="h-px w-full sm:h-auto sm:w-px" data-project-img={projectId}></div>
    <div class="relative w-full">
      <!-- Sizing placeholder -->
      <div aria-hidden="true" class="invisible">
        <div class="flex flex-wrap items-center justify-between gap-x-8 gap-y-2 pb-4">
          <h1 class="mb-0 transition-all duration-200">
            {frontmatter.name}
          </h1>
          <div><ProjectLinks {...frontmatter} /></div>
        </div>
        <div class="w-full">
          <p class="-mt-4 mb-0 w-fit">
            {frontmatter.description}
          </p>
        </div>
        <div class="grid pt-2 transition-all duration-200">
          <div class="overflow-hidden">
            <ChipList awards={frontmatter.awards?.split(/, ?/)} skills={frontmatter.skills?.split(/, ?/)} />
          </div>
        </div>
      </div>

      <!-- Display -->
      <div class="absolute left-0 top-0 w-full" id="project-header-visible">
        <div class="bg-background flex flex-wrap items-center justify-between gap-x-8 gap-y-2 pb-4">
          <h1 class="mb-0 transition-[font-size] duration-200" data-project-title={projectId}>
            {frontmatter.name}
          </h1>
          <div data-project-links={projectId}><ProjectLinks {...frontmatter} /></div>
        </div>
        <div class="bg-background w-full pb-2">
          <p class="-mt-4 mb-0 w-fit transition-[font-size]" data-project-desc={projectId}>
            {frontmatter.description}
          </p>
        </div>
        <div id="project-header-collapse" class="relative transition-opacity duration-200">
          <div class="bg-background absolute left-0 top-0 flex w-full items-center overflow-hidden transition-[height]" id="project-header-collapse-bg">
            <div class="z-10" data-project-chips={projectId}>
              <ChipList awards={frontmatter.awards?.split(/, ?/)} skills={frontmatter.skills?.split(/, ?/)} projectId={projectId} />
            </div>
          </div>
          <div aria-hidden="true" class="invisible">
            <ChipList awards={frontmatter.awards?.split(/, ?/)} skills={frontmatter.skills?.split(/, ?/)} projectId={projectId} />
          </div>
        </div>
      </div>
    </div>
  </div>
  <div id="project-content" class="animate-delay-100 animate-fill-both z-10">
    <Content />
  </div>
  <div class="font-sans"></div>
</Layout>
