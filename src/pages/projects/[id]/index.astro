---
import Layout from "@/layouts/Layout.astro";

import type { GetStaticPaths } from "astro";
import ProjectLinks from "@/components/ProjectLinks.astro";
import ChipList from "@/components/ChipList.astro";

const projects = import.meta.glob("/content/{projects,projects-hackathon}/*.md", { eager: true });
const project = Object.entries(projects).find(([k, p]) => k.split("/").slice(-1)[0].split("-").slice(1).join("-").split(".")[0] === Astro.params.id)![1];
const { Content, frontmatter } = project as Record<string, any>;

export const getStaticPaths = (() => {
  const matches = import.meta.glob("/content/{projects,projects-hackathon}/*.md", { eager: true });
  const projects = Object.keys(matches).map((p) => p.split("/").slice(-1)[0].split("-").slice(1).join("-").split(".")[0]);
  return projects.map((p) => ({ params: { id: p } }));
}) satisfies GetStaticPaths;
---

<Layout
  title={frontmatter.name}
  description={frontmatter.description}
  class="prose prose-slate prose-strong:font-bold prose-h1:font-medium prose-li:marker:text-inherit prose-img:max-h-96 prose-h1:font-sans prose-img:max-w-full prose-img:object-contain *:w-full flex max-w-2xl flex-col items-center"
>
  <div class="mb-8 flex flex-wrap items-center justify-between gap-x-8 gap-y-2">
    <h1 class="mb-0">{frontmatter.name}</h1>
    <ProjectLinks {...frontmatter} />
  </div>
  <div class="-mt-4">
    <ChipList awards={frontmatter.awards?.split(/, ?/)} skills={frontmatter.skills?.split(/, ?/)} />
  </div>
  <Content />
  <div class="font-sans"></div>
</Layout>
